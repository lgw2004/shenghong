# ── MinIO / S3（可以继续用你的国内服务器，或换美国节点）──────────
MINIO_ENDPOINT=121.43.60.72:9010
MINIO_ACCESS_KEY=aIR9gFFJCYfEaPHRoe2l
MINIO_SECRET_KEY=pOxN2QjaniBJcqeuPSd2BEVpRk0sluPbJ316wI1R
MINIO_BUCKET=dev-sherp
MINIO_SECURE=false
MINIO_REGION=cn-south-1

# ── Proxy（美国服务器部署重点）───────────────────────────────
# 美国站直连：留空
PROXY_SERVER=
# 如需欧洲站代理，配 socks5://xray:10808（需启动 xray 容器）
# PROXY_SERVER=socks5://xray:10808

# 按站点代理（JSON），美国站空值=直连，欧洲站走代理
# PROXY_MAP={"US":"","UK":"socks5://xray:10808","DE":"socks5://xray:10808","FR":"socks5://xray:10808","ES":"socks5://xray:10808"}

# ── Crawler ────────────────────────────────────────────────
# 美国服务器访问 Amazon.com 快，延迟可以调低
CRAWLER_DELAY_SECONDS=1
CRAWLER_MAX_RETRIES=3
CRAWLER_CONCURRENCY=3
CRAWLER_BROWSER_CHANNEL=""
